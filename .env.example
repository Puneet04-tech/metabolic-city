# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
WEATHER_API_KEY=your_weather_api_key_here

# AI Model Configuration
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-1.5-flash
MISTRAL_MODEL=mistral-large-latest

# GTFS-RT Endpoints
GTFS_RT_VEHICLE_POSITIONS_URL=https://example.com/gtfs-rt/vehicle-positions
GTFS_RT_TRIP_UPDATES_URL=https://example.com/gtfs-rt/trip-updates
GTFS_STATIC_URL=https://example.com/gtfs-static.zip

# Weather API Configuration
WEATHER_API_PROVIDER=openweathermap
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# Database Configuration
DATABASE_URL=sqlite:///metabolic_city/data/metabolic_city.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Pipeline Settings
PIPELINE_CYCLE_MINUTES=10
PIPELINE_ENABLED=true
RISK_THRESHOLD=7.0

# Domain Weights (must sum to 1.0)
WEIGHT_MOBILITY=0.4
WEIGHT_CLIMATE=0.3
WEIGHT_VULNERABILITY=0.3

# Geohash Configuration
GEOHASH_PRECISION=6

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/metabolic_city.log

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Forecasting Settings
FORECASTING_HORIZON_HOURS=24
FORECASTING_ENABLED=true

# Simulation Settings
SIMULATION_ENABLED=true

# Feedback Integration
FEEDBACK_ENABLED=true
FEEDBACK_API_ENDPOINT=https://example.com/api/feedback

# Dispatch Settings
DISPATCH_ENABLED=true
DISPATCH_TRANSIT_SYSTEM=https://example.com/transit/api
DISPATCH_PUBLIC_WORKS=https://example.com/public-works/api
DISPATCH_EMERGENCY_SERVICES=https://example.com/emergency/api
